{
  "name": "daive",
  "private": true,
  "productName": "Skuber+ Client",
  "displayProductName": "Skuber⁺ Client",
  "description": "skuber⁺ client - Kubernetes Management Client",
  "homepage": "https://skuberplus.app",
  "version": "0.6.5",
  "buildNumber": "20260414171422",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wondermove-Inc/skuberplus-client.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Wondermove-Inc/skuberplus-client/issues"
  },
