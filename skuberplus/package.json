    "email": "starlord@wondermove.net"
  },
  "scripts": {
    "clean": "pnpm dlx rimraf@6.0.1 binaries dist static/build",
    "clean:node_modules": "pnpm dlx rimraf@6.0.1 node_modules",
    "prebuild": "node ../scripts/build-logger.js start 'skuberplus' '프로덕션 빌드 시작...'",
    "build": "NODE_ENV=production webpack --config webpack/webpack.ts --progress",
    "postbuild": "pnpm build:resources && node ../scripts/build-logger.js success 'skuberplus' '프로덕션 빌드 완료' && pnpm verify:build",
    "verify:build": "node ../scripts/verify-build.js",
    "build:resources": "pnpm build:resources:client && pnpm build:resources:tray",
    "build:resources:client": "ensure-binaries --package package.json --base-dir binaries/client",
    "build:resources:tray": "generate-tray-icons --output static/build/tray --input @skuberplus/icon/icons/logo-lens.svg --notice-icon @skuberplus/icon/icons/notice.svg --spinner-icon @skuberplus/icon/icons/arrow-spinner.svg --none-color 125AED",
    "prebuild:app": "node ../scripts/build-logger.js start 'skuberplus' 'ARM64 네이티브 모듈 재빌드 시작...' && pnpm electron-rebuild && node ../scripts/build-logger.js success 'skuberplus' 'ARM64 네이티브 모듈 재빌드 완료'",
    "build:app": "pnpm dlx run-script-os@1.1.6 --",
    "build:app:darwin": "node ../scripts/update-build-version.js && ensure-binaries --package package.json --base-dir binaries/client --platform darwin --arch arm64 && node ../scripts/build-logger.js start 'skuberplus' 'macOS ARM64 앱 패키징 시작...' && electron-builder --publish always --macos --arm64 && node ../scripts/build-logger.js success 'skuberplus' 'macOS ARM64 앱 패키징 완료'",
    "build:app:default": "node ../scripts/update-build-version.js && node ../scripts/build-logger.js start 'skuberplus' '앱 패키징 시작...' && electron-builder --publish always && node ../scripts/build-logger.js success 'skuberplus' '앱 패키징 완료'",
    "build:app:linux": "node ../scripts/update-build-version.js && node ../scripts/build-logger.js start 'skuberplus' 'Linux 앱 패키징 시작...' && node -e \"require('fs').mkdirSync('dist/'+require('./package.json').version,{recursive:true})\" && electron-builder --publish always --linux && node ../scripts/build-logger.js success 'skuberplus' 'Linux 앱 패키징 완료'",
    "build:app:win32": "node ../scripts/update-build-version.js && node ../scripts/build-logger.js start 'skuberplus' 'Windows 앱 패키징 시작...' && node -e \"require('fs').mkdirSync('dist/'+require('./package.json').version,{recursive:true})\" && electron-builder --win --publish always && node ../scripts/build-logger.js success 'skuberplus' 'Windows 앱 패키징 완료'",
    "build:app:win:x64": "node ../scripts/update-build-version.js && node ../scripts/build-logger.js start 'skuberplus' 'Windows x64 앱 패키징 시작...' && node -e \"require('fs').mkdirSync('dist/'+require('./package.json').version,{recursive:true})\" && electron-builder --win --x64 --publish always && node ../scripts/build-logger.js success 'skuberplus' 'Windows x64 앱 패키징 완료'",
    "build:resources:win:x64": "ensure-binaries --package package.json --base-dir binaries/client --platform windows --arch x64",
    "prebuild:app:darwin:x64": "node ../scripts/build-logger.js start 'skuberplus' 'x64 네이티브 모듈 재빌드 시작...' && electron-rebuild -f --arch=x64 && node ../scripts/build-logger.js success 'skuberplus' 'x64 네이티브 모듈 재빌드 완료'",
    "build:app:darwin:x64": "node ../scripts/update-build-version.js && ensure-binaries --package package.json --base-dir binaries/client --platform darwin --arch x64 && node ../scripts/build-logger.js start 'skuberplus' 'macOS x64 앱 패키징 시작...' && electron-builder --publish always --macos --x64 && node ../scripts/build-logger.js success 'skuberplus' 'macOS x64 앱 패키징 완료'",
    "build:resources:darwin:x64": "ensure-binaries --package package.json --base-dir binaries/client --platform darwin --arch x64",
    "postbuild:app": "echo 'Build complete'",
    "electron-rebuild": "electron-rebuild -f",
    "jest": "jest",
    "start": "pnpm dlx run-script-os@1.1.6 --",
    "start:darwin": "pnpm start:darwin:${npm_config_arch:-$(uname -m)}",
    "start:darwin:arm64": "./dist/mac-arm64/SkuberPlus.app/Contents/MacOS/SkuberPlus",
    "start:darwin:x64": "./dist/mac/SkuberPlus.app/Contents/MacOS/SkuberPlus",
    "start:darwin:x86_64": "./dist/mac/SkuberPlus.app/Contents/MacOS/SkuberPlus",
    "start:default": "exit 1",
    "start:linux": "pnpm start:linux:${npm_config_arch:-$(uname -m)}",
    "start:linux:arm64": "./dist/linux-arm64-unpacked/skuberplus-client",
    "start:linux:x64": "./dist/linux-unpacked/skuberplus-client",
    "start:linux:x86_64": "./dist/linux-unpacked/skuberplus-client",
    "start:win32": "dist\\win-unpacked\\SkuberPlus.exe",
    "predev": "pnpm build:resources:tray",
    "dev": "concurrently -i -k \"pnpm dev:run\" npm:dev:build",
    "dev:run": "cross-env NODE_ENV=development nodemon --watch ./static/build/main.js --exec \"node ./scripts/run-electron-dev.js\"",
    "dev:build": "pnpm \"/^dev:build:/\"",
    "postdev:build": "pnpm build:resources",
    "dev:build:main": "cross-env NODE_ENV=development webpack --config webpack/main.ts --progress --watch",
    "dev:build:renderer": "cross-env NODE_ENV=development ts-node ./webpack/dev-server.ts",
    "test:integration": "jest -xyz --runInBand --detectOpenHandles --forceExit",
    "version:build": "node ../scripts/update-build-version.js",
    "version:patch": "node ../scripts/update-build-version.js patch",
    "version:minor": "node ../scripts/update-build-version.js minor",
    "version:major": "node ../scripts/update-build-version.js major",
    "build:resources:darwin:arm64": "ensure-binaries --package package.json --base-dir binaries/client --platform darwin --arch arm64"
  },
  "config": {
    "k8sProxyVersion": "1.0.0",
    "bundledKubectlVersion": "1.34.1",
    "bundledHelmVersion": "3.19.0",
    "contentSecurityPolicy": "script-src 'unsafe-eval' 'self'; frame-src https://*.renderer.skuberplus.app:*/ http://localhost:* http://*:* https://*:*; img-src * data:",
    "welcomeRoute": "/welcome",
    "observabilityUrl": "http://localhost:8080",
    "bundledTrivyVersion": "0.69.3",
    "bundledKubescapeVersion": "4.0.2"
