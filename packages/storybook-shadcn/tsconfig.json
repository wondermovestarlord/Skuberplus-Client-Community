{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "outDir": "dist",
    "paths": {
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noImplicitReturns": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/templates/**/*"]
}
