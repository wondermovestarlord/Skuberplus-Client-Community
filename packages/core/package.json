  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wondermove-Inc/Skuberplus-Client-Community.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/Wondermove-Inc/Skuberplus-Client-Community/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "static/build/main.js",
  "exports": {
    "./package.json": "./package.json",
    "./main": "./static/build/library/main.js",
    "./renderer": "./static/build/library/renderer.js",
    "./styles": "./static/build/library/renderer.css",
    "./globals.css": "./static/build/library/globals.css",
    "./template.html": "./src/renderer/template.html",
    "./vars.scss": "./src/renderer/components/vars.scss",
    "./fonts": "./static/build/library/fonts"
  },
  "typesVersions": {
    "*": {
      "main": [
        "./static/build/library/src/main/library.d.ts"
      ],
      "renderer": [
        "./static/build/library/src/renderer/library.d.ts"
      ]
    }
  },
  "files": [
    "build/*.plist",
    "build/installer.nsh",

    "static/build/library/**/*",
    "src/renderer/template.html",
    "src/renderer/components/vars.scss",
    "types/*",
    "tsconfig.json"
  ],
  "copyright": "© 2024-2025 Wondermove Inc.",
  "license": "MIT",
  "author": {
    "name": "Wondermove Inc.",
    "email": "starlord@wondermove.net"
  },
  "scripts": {
    "build:theme": "tsx src/renderer/themes/generate-css-vars.ts",
    "prebuild": "cd ../.. && node scripts/build-logger.js start '@skuberplus/core' '프로덕션 빌드 시작...'",
    "build": "NODE_ENV=production webpack --config webpack/library-bundle.ts --progress",
    "postbuild": "cd ../.. && node scripts/build-logger.js success '@skuberplus/core' '프로덕션 빌드 완료'",
    "predev": "cd ../.. && node scripts/build-logger.js start '@skuberplus/core' '개발 모드 시작 (watch)...'",
    "dev": "NODE_ENV=development webpack --config webpack/library-bundle.ts --progress --watch",
    "clean": "pnpm dlx rimraf@6.0.1 dist static/build",
    "clean:node_modules": "pnpm dlx rimraf@6.0.1 node_modules",
    "test:unit": "jest",
    "test:watch": "jest --watch --testPathIgnorePatterns integration",
    "knip": "pnpm dlx knip@5.64.0 --dependencies",
    "knip:production": "pnpm dlx knip@5.64.0 --dependencies --production --strict"
  },
