{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "outDir": "static/build/library/",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "*": ["node_modules/*", "types/*"]
    },
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "namedExports": false
        }
      }
    ]
  },
  "include": ["package.json", "webpack/vars.ts", "src/**/*", "types/*.d.ts"],
  "exclude": [
    "node_modules",
    "src/renderer/templates/base-structure-template.tsx",
    "src/renderer/templates/sidebar-template.tsx",
    "src/**/*-origin.tsx",
    "src/**/*-origin.ts",
    "src/**/*-origin.scss",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
