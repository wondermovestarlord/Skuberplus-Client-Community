{
  "$schema": "https://json.schemastore.org/stylelintrc",
  "customSyntax": null,
  "defaultSeverity": "warning",
  "reportDescriptionlessDisables": true,
  "reportInvalidScopeDisables": true,
  "reportNeedlessDisables": true,
  "rules": {
    "color-no-hex": [
      true,
      {
        "message": "THEME-015: Hex 색상 금지. CSS 변수(var(--color-*)) 또는 디자인 토큰을 사용하세요. (color-no-hex)",
        "severity": "warning"
      }
    ],
    "color-named": [
      "never",
      {
        "message": "THEME-015: 명명된 색상 금지. CSS 변수(var(--color-*))를 사용하세요. (color-named)",
        "severity": "warning"
      }
    ],
    "function-disallowed-list": [
      ["rgb", "rgba", "hsl", "hsla", "hwb", "lch"],
      {
        "message": "THEME-015: 색상 함수 금지. CSS 변수(var(--color-*)) 또는 oklch()를 사용하세요. (function-disallowed-list)",
        "severity": "warning"
      }
    ],
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["tailwind", "apply", "layer", "theme", "utility", "custom-variant", "source", "config"]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["theme", "oklch", "color-mix"]
      }
    ],
    "import-notation": null,
    "selector-class-pattern": null
  },
  "ignoreFiles": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/*.min.css"]
}
